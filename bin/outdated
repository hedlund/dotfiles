#!/usr/bin/env node

'use strict';

const exec = require('child_process').exec;
const outdated = require('./lib/outdated');

function logResults(title, outdated) {
	const headline = `\nOutdated ${title} packages`;
	console.log(headline);
	console.log('='.repeat(headline.length-1));
	outdated.forEach(app => console.log(`    ${app}`));
}

outdated.brew(outdated => logResults('Homebrew', outdated));
outdated.cask(outdated => logResults('Homebrew Cask', outdated));
outdated.sdk(outdated => logResults('SDKMAN!', outdated));
outdated.npm(outdated => logResults('NPM', outdated));
outdated.apm(outdated => logResults('APM', outdated));
