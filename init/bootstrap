#!/usr/bin/env bash

PUBLIC_GPG_KEY=93B0E5FD
CURRENT=$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )
DOTFILES=$( cd "$CURRENT/.." && pwd )

#-------------------------------------------------------------------------------
# Symlink all the dotfiles
ignored_files=(gitconfig init tag-personal tag-work LICENSE-MIT.txt mackup.cfg rcrc README.md)
ignored() {
    local e
    for e in "${ignored_files[@]}"; do
        [[ "$e" == "$1" ]] && return 0
    done
    return 1
}
for path in $DOTFILES/*; do
    file=$(basename $path)
    if ! ignored $file; then
        ln -sf $path $HOME/.$file
    fi
done;
\cp $DOTFILES/gitconfig $HOME/.gitconfig

#-------------------------------------------------------------------------------
# Run the script for the respective platform
case "$(uname -s)" in
    Darwin) $CURRENT/bootstrap-osx.sh ;;
    Linux) $CURRENT/bootstrap-linux.sh ;;
    CYGWIN*|MINGW32*|MSYS*) $CURRENT/bootstrap-win.sh ;;
    *) echo "Running on unknown OS. Aborting!" ; exit 1 ;;
esac

#-------------------------------------------------------------------------------
# Install the Node dependencies for the CLI scripts
if command -v npm >/dev/null 2>&1; then
    ( cd "$DOTFILES/bin" && npm install )
fi