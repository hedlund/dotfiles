# Add `~/.bin` to the `$PATH`
export PATH="$HOME/.bin:$PATH";

# Add /usr/local/sbin
export PATH="/usr/local/sbin:$PATH";

# Add Go
if [[ $OSTYPE =~ linux* ]]; then
    export PATH=$PATH:$HOME/.local/share/umake/go/go-lang/bin
fi
export GOPATH=$HOME/Projects/golang
export PATH=$PATH:$GOPATH/bin

# Add environment variable COCOS_CONSOLE_ROOT for cocos2d-x
export COCOS_X_ROOT=$HOME/Projects/cocos2d/sdk/cocos2d-x-latest
export COCOS_CONSOLE_ROOT=$COCOS_X_ROOT/tools/cocos2d-console/bin
export COCOS_TEMPLATES_ROOT=$COCOS_X_ROOT/templates
export PATH=$COCOS_X_ROOT:$COCOS_CONSOLE_ROOT:$COCOS_TEMPLATES_ROOT:$PATH

# Add environment variables for Godot Engine
export GODOT_ROOT=$HOME/Projects/godot/godot-master

# Add Android
if [[ $OSTYPE =~ darwin* ]]; then
    export ANDROID_HOME=$HOME/Library/Android/sdk
    export ANDROID_SDK_ROOT=$ANDROID_HOME
    export PATH=$ANDROID_HOME/tools/bin:$PATH
fi
