# Adding Postgres to path
export PATH=~/Applications/Postgres.app/Contents/Versions/9.4/bin:$PATH

# Adding Android
export ANDROID_HOME=/usr/local/opt/android-sdk

# Adding Java
export JAVA_HOME=/Library/Java/JavaVirtualMachines/jdk1.8.0_45.jdk/Contents/Home/

# Adding Tomcat
export CATALINA_BASE=/usr/local/Cellar/tomcat/8.0.22/libexec
export CATALINA_HOME=$CATALINA_BASE

# Adding Ant
export ANT_HOME=/usr/local/Cellar/ant/1.9.4/libexec

# Adding Conscript
export PATH=$HOME/bin:$PATH

# Adding Scalatra JRebel
export SCALATRA_JREBEL=$HOME/Dropbox/Scripts/jrebel/jrebel.jar

if [[ $OSTYPE =~ linux* ]]; then

    # Adding jEnv
    export PATH=$HOME/.jenv/bin:$PATH

fi
